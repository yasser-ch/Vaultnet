<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="40sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VaultNet"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIcon"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Communication réseau sécurisée"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Section Protocoles -->
        <TextView
            android:id="@+id/tvProtoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTOCOLES"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llProto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvProtoLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetrofit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📡  Retrofit + TLS"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHttp3"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⚡  HTTP/3 QUIC"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWebSocket"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔄  WebSocket"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

        </LinearLayout>

        <!-- Section Sécurité -->
        <TextView
            android:id="@+id/tvSecLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SÉCURITÉ"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/llProto"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llSec"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvSecLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMtls"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔐  Mutual TLS"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDoh"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🛡️  DNS-over-HTTPS"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCt"
                style="@style/VaultButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📜  Certificate Transparency"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/purple_dim"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚀  Atelier Final"
                android:textSize="15sp"
                app:backgroundTint="@color/teal_accent"
                app:cornerRadius="14dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>