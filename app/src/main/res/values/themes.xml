<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VaultNet" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#7C6FFF</item>
        <item name="colorPrimaryVariant">#5A50CC</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00E5C0</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">#1C1B29</item>
        <item name="colorOnSurface">#EEEEFF</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="materialButtonStyle">@style/VaultButton</item>
    </style>

    <style name="VaultButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="VaultButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">14dp</item>
    </style>
</resources>